{
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:docs.openshift.com)",
      "Skill(jira)"
    ]
  },
  "enabledPlugins": {
    "jira@ai-helpers": true,
    "gcp-hcp@gcp-hcp": true
  },
  "extraKnownMarketplaces": {
    "openshift-ai-helpers": {
      "source": {
        "source": "github",
        "repo": "openshift-eng/ai-helpers"
      }
    },
    "gcp-hcp": {
      "source": {
        "source": "github",
        "repo": "openshift-online/gcp-hcp"
      }
    }
  }
}
